DATABASE_URL="postgresql://dataarena:dataarena_dev@localhost:5432/dataarena?schema=public"
# Production (Supabase): use Direct connection URI from Supabase → Settings → Database
# postgresql://postgres.xxx:PASSWORD@db.xxx.supabase.co:5432/postgres?sslmode=require
REDIS_URL="redis://localhost:6379"

PORT=4000
NODE_ENV=development

FRONTEND_URL="http://localhost:3000"

JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

COOKIE_SECURE="false"
# In production, secure cookies are enabled automatically when NODE_ENV=production.
# Set COOKIE_SECURE="true" explicitly if needed.

{
  "name": "dataarena",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "dev:api": "npm run start:dev --workspace=api",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web && npm run build --workspace=api",
    "build:web": "npm run build --workspace=web",
    "build:api": "npm run build --workspace=api",
    "lint": "npm run lint --workspace=web && npm run lint --workspace=api",
    "start": "npm run start --workspace=web",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate --workspace=api"
  }
}
